function TcadPiadas.SomenteNumeros(const Texto:string):string;
var
  I:Integer;
begin
  Result:='';

  for I:= 1 to Length(Texto) do
    if Texto[I] in ['0'..'9'] then
    Result:= Result+Texto[I];
end;

end.
