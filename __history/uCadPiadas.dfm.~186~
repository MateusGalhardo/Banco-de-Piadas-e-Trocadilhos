  object QryPiadas: TFDQuery
    Connection = dtmPiadas.conexaoPiadas
    SQL.Strings = (
      'select'
      '  p.piadaId,'
      '  isnull(p.texto, '#39#39') as texto,'
      '  isnull(p.categoria, '#39#39') as categoria,'
      '  isnull(p.tipo, '#39#39') as tipo,'
      '  p.dataPiada,'
      '  isnull(c.classificacao, '#39#39') as classificacao'
      'from piadas p'
      'left join classificacoes c on c.Id = p.classificacaoId where 1=1')
